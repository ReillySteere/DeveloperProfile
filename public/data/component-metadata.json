  {
    "name": "VitalGauge",
    "description": "Radial gauge displaying a single Web Vital metric with color-coded rating",
    "category": "Data Display",
    "renderMode": "direct",
    "props": [
      {
        "name": "name",
        "type": "string",
        "controlType": "string",
        "required": true,
        "defaultValue": "LCP"
      },
      {
        "name": "value",
        "type": "number",
        "controlType": "number",
        "required": true,
        "defaultValue": "2200"
      },
      {
        "name": "rating",
        "type": "'good' | 'needs-improvement' | 'poor'",
        "controlType": "select",
        "required": true,
        "defaultValue": "needs-improvement",
        "options": [
          { "label": "good", "value": "good" },
          { "label": "needs-improvement", "value": "needs-improvement" },
          { "label": "poor", "value": "poor" }
        ]
      },
      {
        "name": "unit",
        "type": "string",
        "controlType": "string",
        "required": true,
        "defaultValue": "ms"
      },
      {
        "name": "thresholds",
        "type": "{ good: number; poor: number }",
        "controlType": "json",
        "required": true
      }
    ],
    "sampleData": {
      "thresholds": { "good": 2500, "poor": 4000 }
    },
    "examples": [
      {
        "name": "Good LCP",
        "props": {
          "name": "LCP",
          "value": 1800,
          "rating": "good",
          "unit": "ms",
          "thresholds": { "good": 2500, "poor": 4000 }
        }
      }
    ],
    "importPath": "ui/containers/performance/components/VitalGauge"
  },
  {
    "name": "WebVitalsDisplay",
    "description": "Dashboard panel showing all Web Vitals metrics with gauges",
    "category": "Data Display",
    "renderMode": "direct",
    "props": [
      {
        "name": "vitals",
        "type": "Partial<WebVitals>",
        "controlType": "json",
        "required": true
      }
    ],
    "sampleData": {
      "vitals": {
        "lcp": 2200,
        "fcp": 1500,
        "cls": 0.05,
        "ttfb": 600
      }
    },
    "examples": [
      {
        "name": "Default",
        "props": {
          "vitals": { "lcp": 2200, "fcp": 1500, "cls": 0.05, "ttfb": 600 }
        }
      }
    ],
    "importPath": "ui/containers/performance/components/WebVitalsDisplay"
  },
  {
    "name": "BundleSizeTreemap",
    "description": "Treemap visualization of JavaScript bundle modules and their sizes",
    "category": "Data Display",
    "renderMode": "direct",
    "props": [
      {
        "name": "modules",
        "type": "BundleModule[]",
        "controlType": "json",
        "required": true
      },
      {
        "name": "totalSize",
        "type": "number",
        "controlType": "number",
        "required": true,
        "defaultValue": "500000"
      },
      {
        "name": "gzippedSize",
        "type": "number",
        "controlType": "number",
        "required": true,
        "defaultValue": "150000"
      }
    ],
    "sampleData": {
      "modules": [
        {
          "name": "main.js",
          "path": "dist/main.js",
          "size": 300000,
          "gzippedSize": 90000,
          "isInitial": true
        },
        {
          "name": "vendor.js",
          "path": "dist/vendor.js",
          "size": 200000,
          "gzippedSize": 60000,
          "isInitial": true
        }
      ]
    },
    "examples": [
      {
        "name": "Default",
        "props": { "modules": [], "totalSize": 500000, "gzippedSize": 150000 }
      }
    ],
    "importPath": "ui/containers/performance/components/BundleSizeTreemap"
  },
  {
    "name": "CodeComparisonViewer",
