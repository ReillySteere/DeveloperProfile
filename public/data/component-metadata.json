    "props": [
      {
        "name": "comparisons",
        "type": "CodeComparison[]",
        "controlType": "json",
        "required": true
      }
    ],
    "sampleData": {
      "comparisons": [
        {
          "title": "ES Modules Migration",
          "description": "Converting CommonJS to ES module syntax",
          "before": "const x = require('module');",
          "after": "import x from 'module';",
          "language": "typescript"
        }
      ]
    },
    "examples": [{ "name": "Default", "props": { "comparisons": [] } }],
    "importPath": "ui/containers/case-studies/components/CodeComparisonViewer"
  },
